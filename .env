# Ouroboros Configuration
# Copy this file to .env and fill in your values
# NEVER commit .env to version control (already in .gitignore)

# =============================================================================
# REQUIRED
# =============================================================================

# OpenRouter API key (get from https://openrouter.ai/keys)
OPENROUTER_API_KEY=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

# Telegram bot token (get from @BotFather on Telegram)
TELEGRAM_BOT_TOKEN=8210860261:AAFCvCtfojlu9wxwbmPlyup-MSwFsrslYnI

# GitHub personal access token (with repo scope)
# Get from https://github.com/settings/tokens
GITHUB_TOKEN=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

# GitHub username and repository
GITHUB_USER=josolinap
GITHUB_REPO=jo

# Total budget in USD (stops agent when exceeded)
TOTAL_BUDGET=50

# LLM Provider: openrouter, local, or opencode
LLM_PROVIDER=openrouter

# Opencode model (use free models)
OPENCODE_MODEL=openrouter/free

# =============================================================================
# OPTIONAL: Storage
# =============================================================================

# Local data storage (default: ~/.ouroboros)
# DATA_ROOT=~/.ouroboros

# Repository location (default: current directory)
# REPO_DIR=.

# =============================================================================
# OPTIONAL: Models (OpenRouter model IDs)
# =============================================================================

# Default main model (used for general conversation)
# Default: anthropic/claude-sonnet-4.6
OUROBOROS_MODEL=openrouter/free

# Model used for code tasks
# Default: anthropic/claude-sonnet-4.6
OUROBOROS_MODEL_CODE=openrouter/free

# Light model for background consciousness
# Default: google/gemini-3-pro-preview
OUROBOROS_MODEL_LIGHT=openrouter/free

# Model used for web search
# Default: openai/gpt-4.1-mini
OUROBOROS_WEBSEARCH_MODEL=openrouter/free

# Fallback models (comma-separated, tried in order if primary fails)
OUROBOROS_MODEL_FALLBACK_LIST=openrouter/free

# =============================================================================
# OPTIONAL: API Keys for specific features
# =============================================================================

# OpenAI API key (enables web search via OpenAI)
# OPENAI_API_KEY=

# Anthropic API key (enables Claude Code CLI tool)
# ANTHROPIC_API_KEY=

# =============================================================================
# OPTIONAL: Behavior
# =============================================================================

# Max conversation rounds per task (default: 200)
# OUROBOROS_MAX_ROUNDS=150

# Enable/disable evolution mode (default: enabled)
# OUROBOROS_EVOLUTION_MODE=1

# Enable/disable background consciousness (default: enabled)
# OUROBOROS_CONSCIOUSNESS=1

# Run pre-push tests before git push (default: 1)
# OUROBOROS_PRE_PUSH_TESTS=1

# Skip git sync on startup (use for local development, default: 0)
OUROBOROS_NO_GIT_SYNC=1

# Worker start method (fork/spawn, default: fork on Linux)
# OUROBOROS_WORKER_START_METHOD=fork

# Background consciousness budget percentage (default: 10)
# OUROBOROS_BG_BUDGET_PCT=10

# Enable opencode as last resort fallback when all models fail (default: enabled)
OUROBOROS_OPENCODE_FALLBACK=1