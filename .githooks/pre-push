#!/bin/bash
# Pre-push hook: validates code before allowing push
# Install: cp .githooks/pre-push .git/hooks/pre-push && chmod +x .git/hooks/pre-push

echo "Running pre-push validation..."

# Syntax check all Python files
echo "Checking Python syntax..."
python3 -m py_compile ouroboros/*.py 2>/dev/null || { echo "✗ Syntax errors in ouroboros/*.py"; exit 1; }
python3 -m py_compile ouroboros/tools/*.py 2>/dev/null || { echo "✗ Syntax errors in ouroboros/tools/*.py"; exit 1; }
python3 -m py_compile supervisor/*.py 2>/dev/null || { echo "✗ Syntax errors in supervisor/*.py"; exit 1; }
echo "✓ Syntax OK"

# Critical imports check
echo "Checking critical imports..."
python3 -c "from ouroboros.tools.registry import ToolRegistry" 2>/dev/null || { echo "✗ ToolRegistry import failed"; exit 1; }
python3 -c "from ouroboros.vault_manager import VaultManager" 2>/dev/null || { echo "✗ VaultManager import failed"; exit 1; }
python3 -c "from supervisor.state import init" 2>/dev/null || { echo "✗ supervisor.state import failed"; exit 1; }
echo "✓ Imports OK"

# Run smoke tests
echo "Running smoke tests..."
python3 -m pytest tests/test_smoke.py -q --tb=short 2>/dev/null || { echo "✗ Smoke tests failed"; exit 1; }
echo "✓ Tests OK"

echo "✅ Pre-push validation passed"
